@model IEnumerable<Juanfewi.Models.Event>

@{
    ViewData["Title"] = "Panel de Eventos";
    var totalEvents = Model.Count();
    var activeEvents = Model.Count(e => e.IsActive);
    var inactiveEvents = Model.Count(e => !e.IsActive);
}

<div class="section">
    <div class="card-panel z-depth-3 hero-panel">
        <div class="row valign-wrapper" style="margin-bottom: 0;">
            <div class="col s12 m8">
                <h3 class="white-text" style="margin-top: 0; font-weight: 700;">
                    Panel de Gestión Gamer
                </h3>
                <p class="grey-text text-lighten-3 flow-text" style="margin-bottom: 0;">
                    Administra torneos, eventos y experiencias gaming desde un solo lugar.
                </p>
            </div>

            <div class="col s12 m4 right-align" style="margin-top: 20px;">
                <a asp-action="Create" class="btn-large waves-effect waves-light deep-purple lighten-1">
                    <i class="material-icons left">add_circle</i>
                    Crear Evento
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col s12 m4">
        <div class="card summary-card blue-grey darken-3 hoverable">
            <div class="card-content white-text center">
                <i class="material-icons medium">event</i>
                <span class="card-title">Total</span>
                <h4>@totalEvents</h4>
            </div>
        </div>
    </div>

    <div class="col s12 m4">
        <div class="card summary-card green darken-2 hoverable">
            <div class="card-content white-text center">
                <i class="material-icons medium">check_circle</i>
                <span class="card-title">Activos</span>
                <h4>@activeEvents</h4>
            </div>
        </div>
    </div>

    <div class="col s12 m4">
        <div class="card summary-card red darken-2 hoverable">
            <div class="card-content white-text center">
                <i class="material-icons medium">cancel</i>
                <span class="card-title">Inactivos</span>
                <h4>@inactiveEvents</h4>
            </div>
        </div>
    </div>
</div>