<!DOCTYPE html>

<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — PixelFest</title>

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'neon':        '#00ff87',
                        'neon-dark':   '#00b857',
                        'game-purple': '#7c3aed',
                        'game-violet': '#a855f7',
                        'game-blue':   '#0ea5e9',
                        'game-bg':     '#050811',
                        'game-card':   '#0d1117',
                        'game-card2':  '#111827',
                    },
                    fontFamily: {
                        orbitron: ['Orbitron', 'monospace'],
                        rajdhani: ['Rajdhani', 'sans-serif'],
                    },
                }
            }
        }
    </script>
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="bg-game-bg font-rajdhani text-slate-200 min-h-screen overflow-x-hidden bg-grid">


    <div class="fixed top-0 left-0 w-[60%] h-[80%] -translate-x-[20%] -translate-y-[50%] rounded-full
                bg-game-purple/10 blur-[100px] pointer-events-none z-0 animate-breathe"></div>


    <div class="fixed bottom-[-10%] right-[-5%] w-[500px] h-[500px] rounded-full
                bg-neon/[0.07] blur-[80px] pointer-events-none z-0"></div>

    <div class="scanlines"></div>


    <nav class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between
                px-10 h-16 bg-game-bg/85 backdrop-blur-xl border-b border-neon/[0.12]">

        <a asp-controller="Event" asp-action="Index"
           class="font-orbitron font-black text-xl tracking-widest text-gradient-logo flex items-center gap-3 no-underline">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-neon to-game-purple
                        flex items-center justify-center text-base shadow-[0_0_16px_rgba(0,255,135,0.4)]">⬡</div>
            PIXELFEST
        </a>

        <div class="flex items-center gap-2">
            <a asp-controller="Event" asp-action="Index"
               class="font-rajdhani font-semibold text-sm uppercase tracking-widest px-4 py-2 rounded-lg
                      transition-all duration-200 no-underline
                      @(ViewData["ActiveNav"]?.ToString() == "index"
                          ? "text-neon bg-neon/10"
                          : "text-slate-500 hover:text-neon hover:bg-neon/10")">
                Eventos
            </a>
            <a asp-controller="Event" asp-action="Create"
               class="font-orbitron font-bold text-[0.68rem] tracking-widest px-5 py-2 rounded-lg
                      bg-gradient-to-r from-game-purple to-game-violet text-white no-underline
                      shadow-[0_4px_20px_rgba(124,58,237,0.35)] transition-all duration-200
                      hover:-translate-y-0.5 hover:shadow-[0_6px_28px_rgba(124,58,237,0.55)]">
                + CREAR
            </a>
        </div>
    </nav>


    <main class="relative z-10 max-w-[1300px] mx-auto px-10 pt-24 pb-12">
        @RenderBody()
    </main>


    <footer class="relative z-10 border-t border-neon/[0.06] px-10 py-6 flex items-center justify-between flex-wrap gap-4">
        <span class="text-xs font-semibold text-slate-800">
            © 2026 — <span class="text-gradient-logo">PixelFest</span>. Todos los derechos reservados.
        </span>
    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>
