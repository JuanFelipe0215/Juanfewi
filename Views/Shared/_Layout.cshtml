<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PixelFest</title>

    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Juanfewi.styles.css" asp-append-version="true" />
</head>
<body>

<header>
    <nav class="deep-purple darken-3">
        <div class="nav-wrapper container">
            <a asp-controller="Events" asp-action="Index" class="brand-logo">PixelFest</a>

            <ul id="nav-mobile" class="right hide-on-med-and-down">
                <li>
                    <a asp-controller="Events" asp-action="Index">Eventos</a>
                </li>
                <li>
                    <a asp-controller="Events" asp-action="Create">Crear</a>
                </li>
            </ul>
        </div>
    </nav>
</header>

<main class="container" style="margin-top: 30px;">
    @RenderBody()
</main>

<footer class="page-footer deep-purple darken-4" style="margin-top: 40px;">
    <div class="container">
        © 2026 - PixelFest
    </div>
</footer>

<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

<script>
        document.addEventListener('DOMContentLoaded', function () {
            M.AutoInit();
        });
    </script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>