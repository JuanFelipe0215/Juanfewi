<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — PixelFest</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --neon-green: #00ff87;
            --deep-green: #00b857;
            --purple: #7c3aed;
            --purple-light: #a855f7;
            --blue: #0ea5e9;
            --bg-dark: #050811;
            --bg-card: #0d1117;
            --bg-card2: #111827;
            --text: #e2e8f0;
            --text-muted: #64748b;
            --border: rgba(0,255,135,0.15);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Rajdhani', sans-serif;
            background: var(--bg-dark);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image:
                linear-gradient(rgba(0,255,135,0.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(0,255,135,0.04) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
            z-index: 0;
        }

        body::after {
            content: '';
            position: fixed;
            top: -50%; left: -20%;
            width: 60%; height: 80%;
            background: radial-gradient(ellipse, rgba(124,58,237,0.1) 0%, transparent 60%);
            pointer-events: none;
            z-index: 0;
            animation: breathe 8s ease-in-out infinite;
        }

        @@keyframes breathe {
            0%, 100% { opacity: 0.6; transform: scale(1); }
            50% { opacity: 1; transform: scale(1.1); }
        }

        .orb {
            position: fixed;
            bottom: -10%; right: -5%;
            width: 500px; height: 500px;
            background: radial-gradient(ellipse, rgba(0,255,135,0.07) 0%, transparent 65%);
            pointer-events: none;
            z-index: 0;
        }

        .scanlines {
            position: fixed; inset: 0;
            background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.03) 2px, rgba(0,0,0,0.03) 4px);
            pointer-events: none;
            z-index: 9999;
        }

        /* ── NAV ── */
        nav {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2.5rem;
            height: 64px;
            background: rgba(5,8,17,0.85);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0,255,135,0.12);
        }

        .nav-logo {
            font-family: 'Orbitron', monospace;
            font-weight: 900;
            font-size: 1.2rem;
            background: linear-gradient(135deg, var(--neon-green), var(--purple-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 2px;
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .nav-logo-icon {
            width: 32px; height: 32px;
            background: linear-gradient(135deg, var(--neon-green), var(--purple));
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            -webkit-text-fill-color: initial;
            box-shadow: 0 0 16px rgba(0,255,135,0.4);
            flex-shrink: 0;
        }

        .nav-links { display: flex; gap: 0.5rem; align-items: center; }

        .nav-link {
            font-family: 'Rajdhani', sans-serif;
            font-weight: 600;
            font-size: 0.88rem;
            color: var(--text-muted);
            text-decoration: none;
            padding: 0.45rem 1rem;
            border-radius: 8px;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: all 0.2s;
        }

        .nav-link:hover, .nav-link.active {
            color: var(--neon-green);
            background: rgba(0,255,135,0.08);
        }

        .nav-btn {
            font-family: 'Orbitron', monospace;
            font-size: 0.68rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            padding: 0.5rem 1.2rem;
            border: none;
            border-radius: 8px;
            background: linear-gradient(135deg, var(--purple), var(--purple-light));
            color: white;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 4px 20px rgba(124,58,237,0.35);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .nav-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 28px rgba(124,58,237,0.55);
            color: white;
        }

        /* ── MAIN ── */
        main {
            position: relative;
            z-index: 1;
            padding: 88px 2.5rem 3rem;
            max-width: 1300px;
            margin: 0 auto;
        }

        /* ── BUTTONS ── */
        .btn-primary {
            display: inline-flex; align-items: center; gap: 8px;
            font-family: 'Orbitron', monospace;
            font-size: 0.7rem; font-weight: 700; letter-spacing: 1.5px;
            padding: 0.75rem 1.6rem;
            border: none; border-radius: 10px;
            background: linear-gradient(135deg, var(--neon-green), var(--deep-green));
            color: #050811; cursor: pointer;
            transition: all 0.25s;
            box-shadow: 0 4px 24px rgba(0,255,135,0.3);
            text-decoration: none;
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 32px rgba(0,255,135,0.45);
            color: #050811;
        }

        .btn-secondary {
            display: inline-flex; align-items: center; gap: 8px;
            font-family: 'Orbitron', monospace;
            font-size: 0.7rem; font-weight: 700; letter-spacing: 1.5px;
            padding: 0.75rem 1.6rem;
            border-radius: 10px;
            background: transparent;
            color: var(--purple-light);
            border: 1px solid rgba(168,85,247,0.4);
            cursor: pointer;
            transition: all 0.25s;
            text-decoration: none;
        }

        .btn-secondary:hover {
            background: rgba(124,58,237,0.12);
            border-color: var(--purple-light);
            transform: translateY(-3px);
            color: var(--purple-light);
        }

        .btn-danger {
            display: inline-flex; align-items: center; gap: 8px;
            font-family: 'Orbitron', monospace;
            font-size: 0.7rem; font-weight: 700; letter-spacing: 1.5px;
            padding: 0.75rem 1.6rem;
            border-radius: 10px;
            background: transparent;
            color: #f87171;
            border: 1px solid rgba(239,68,68,0.35);
            cursor: pointer;
            transition: all 0.25s;
            text-decoration: none;
        }

        .btn-danger:hover {
            background: rgba(239,68,68,0.1);
            border-color: #f87171;
            transform: translateY(-3px);
            color: #f87171;
        }

        /* ── CARD ── */
        .card {
            background: var(--bg-card);
            border-radius: 20px;
            border: 1px solid var(--border);
            overflow: hidden;
            position: relative;
        }

        .card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--neon-green), transparent);
        }

        .card-header {
            padding: 1.5rem 1.75rem;
            border-bottom: 1px solid rgba(0,255,135,0.08);
            background: rgba(0,255,135,0.02);
        }

        .card-header h2 {
            font-family: 'Orbitron', monospace;
            font-size: 1rem; font-weight: 700;
            color: white; letter-spacing: 1px;
            margin-bottom: 0.2rem;
        }

        .card-header p { font-size: 0.82rem; color: var(--text-muted); }

        .card-body { padding: 1.75rem; }

        /* ── FORM CONTROLS ── */
        .form-group { margin-bottom: 1.4rem; }

        .form-label {
            display: block;
            font-family: 'Orbitron', monospace;
            font-size: 0.65rem; font-weight: 700;
            letter-spacing: 2px; text-transform: uppercase;
            color: var(--text-muted);
            margin-bottom: 0.55rem;
        }

        .form-control {
            width: 100%;
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(0,255,135,0.14);
            border-radius: 10px;
            padding: 0.75rem 1rem;
            font-family: 'Rajdhani', sans-serif;
            font-size: 1rem; font-weight: 500;
            color: var(--text);
            transition: all 0.2s;
            outline: none;
        }

        .form-control:focus {
            border-color: var(--neon-green);
            background: rgba(0,255,135,0.04);
            box-shadow: 0 0 0 3px rgba(0,255,135,0.08);
        }

        .form-control::placeholder { color: #334155; }

        select.form-control option { background: #0d1117; }

        textarea.form-control { resize: vertical; min-height: 110px; }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        /* ── ALERTS ── */
        .alert {
            padding: 0.9rem 1.25rem;
            border-radius: 10px;
            font-size: 0.88rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
            border: 1px solid;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .alert-success {
            background: rgba(0,255,135,0.07);
            border-color: rgba(0,255,135,0.25);
            color: var(--neon-green);
        }

        .alert-danger {
            background: rgba(239,68,68,0.07);
            border-color: rgba(239,68,68,0.25);
            color: #f87171;
        }

        /* ── BADGE ── */
        .badge {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 0.25rem 0.75rem;
            border-radius: 999px;
            font-size: 0.73rem; font-weight: 700;
            letter-spacing: 0.5px; text-transform: uppercase;
        }

        .badge-active {
            background: rgba(0,255,135,0.1);
            color: var(--neon-green);
            border: 1px solid rgba(0,255,135,0.25);
        }

        .badge-inactive {
            background: rgba(249,115,22,0.1);
            color: #fb923c;
            border: 1px solid rgba(249,115,22,0.25);
        }

        .badge-active::before, .badge-inactive::before {
            content: '';
            width: 6px; height: 6px;
            border-radius: 50%;
            background: currentColor;
        }

        @@keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(0,255,135,0.4); }
            50% { box-shadow: 0 0 0 6px rgba(0,255,135,0); }
        }

        .badge-active::before { animation: pulse 2s infinite; }

        /* ── FOOTER ── */
        footer {
            position: relative; z-index: 1;
            border-top: 1px solid rgba(0,255,135,0.06);
            padding: 1.5rem 2.5rem;
            display: flex; align-items: center;
            justify-content: space-between;
            flex-wrap: wrap; gap: 1rem;
        }

        .footer-copy { font-size: 0.78rem; color: #1e293b; font-weight: 600; }
        .footer-copy span {
            background: linear-gradient(90deg, var(--neon-green), var(--purple-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        @@keyframes slideIn {
            from { opacity: 0; transform: translateY(-16px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animate-in { animation: slideIn 0.5s ease-out both; }
        .animate-in-2 { animation: slideIn 0.5s ease-out 0.1s both; }
        .animate-in-3 { animation: slideIn 0.5s ease-out 0.2s both; }
    </style>
</head>
<body>
<div class="scanlines"></div>
<div class="orb"></div>

<nav>
    <a class="nav-logo" asp-controller="Event" asp-action="Index">
        <div class="nav-logo-icon">⬡</div>
        PIXELFEST
    </a>
    <div class="nav-links">
        <a class="nav-link @(ViewData["ActiveNav"]?.ToString() == "index" ? "active" : "")"
           asp-controller="Event" asp-action="Index">Eventos</a>
        <a class="nav-btn" asp-controller="Event" asp-action="Create">+ CREAR</a>
    </div>
</nav>

<main>
    @RenderBody()
</main>

<footer>
    <div class="footer-copy">© 2026 — <span>PixelFest</span>. Todos los derechos reservados.</div>
</footer>

@RenderSection("Scripts", required: false)
</body>
</html>
